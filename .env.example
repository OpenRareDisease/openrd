NODE_ENV=development
PORT=4000
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fshd_openrd
DATABASE_SSL_ENABLED=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:8081,http://localhost:8080
LOG_LEVEL=debug

# OTP
OTP_PROVIDER=mock
OTP_CODE_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_INTERVAL_SECONDS=60
OTP_MAX_SEND_PER_DAY=10
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_HASH_SECRET=change-me-otp-secret
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=20
OTP_SEND_RATE_LIMIT_WINDOW_SECONDS=60
OTP_SEND_RATE_LIMIT_MAX_REQUESTS=5
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15

# AI (Node API)
AI_API_BASE_URL=https://api.siliconflow.cn/v1
AI_API_MODEL=Qwen/Qwen3-VL-32B-Instruct
AI_API_TIMEOUT=30000
OPENAI_API_KEY=
AI_API_KEY=
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_MAX_REQUESTS=6
AI_PROGRESS_RATE_LIMIT_WINDOW_SECONDS=60
AI_PROGRESS_RATE_LIMIT_MAX_REQUESTS=30

# OCR (Baidu)
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_GENERAL_ENDPOINT=https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic
BAIDU_OCR_ACCURATE_ENDPOINT=https://aip.baidubce.com/rest/2.0/ocr/v1/accurate_basic
BAIDU_OCR_MEDICAL_ENDPOINT=https://aip.baidubce.com/rest/2.0/ocr/v1/medical_report

# Integrated report OCR / parser
OCR_PROVIDER=embedded
OCR_PYTHON_BIN=python3
OCR_PARSER_TIMEOUT_MS=120000
OCR_DISABLE_PADDLE=true

# File storage
STORAGE_PROVIDER=local
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin12345678
MINIO_BUCKET_NAME=medical-reports
MINIO_USE_HTTPS=false

# Legacy external report-manager compatibility (optional)
REPORT_MANAGER_OCR_URL=
REPORT_MANAGER_OCR_API_KEY=
REPORT_MANAGER_OCR_USER_ID=
REPORT_MANAGER_MINIO_ENDPOINT=
REPORT_MANAGER_MINIO_ACCESS_KEY=
REPORT_MANAGER_MINIO_SECRET_KEY=
REPORT_MANAGER_MINIO_BUCKET_NAME=
REPORT_MANAGER_MINIO_USE_HTTPS=

# Chroma Cloud
CHROMA_API_KEY=your_chromadb_cloud_api_key_here
CHROMA_TENANT_ID=your_tenant_id_here
CHROMA_DATABASE=FSHD
CHROMA_COLLECTION=fshd_knowledge_base
CHROMA_API_HOST=localhost
CHROMA_API_PORT=5000

# Knowledge service
KB_SERVICE_HOST=127.0.0.1
KB_SERVICE_PORT=5010
KB_SERVICE_URL=
KB_READY_WAIT_SECONDS=90
HEALTHCHECK_TIMEOUT_MS=2500

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:4000/api
WEB_EXPO_PUBLIC_API_URL=/api
